{
  "info": {
    "name": "Favorites API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://127.0.0.1:8000",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Root",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/",
          "host": ["{{base_url}}"],
          "path": [""]
        }
      }
    },
    {
      "name": "Hello",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/hello/World",
          "host": ["{{base_url}}"],
          "path": ["hello", "World"]
        }
      }
    },
    {
      "name": "List Favorites",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/favorites",
          "host": ["{{base_url}}"],
          "path": ["favorites"]
        }
      }
    },
    {
      "name": "Get Favorite",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/favorites/1",
          "host": ["{{base_url}}"],
          "path": ["favorites", "1"]
        }
      }
    },
    {
      "name": "Create Favorite",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"url\": \"github.com\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/favorites",
          "host": ["{{base_url}}"],
          "path": ["favorites"]
        }
      }
    },
    {
      "name": "Update Favorite",
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"url\": \"google.co.uk\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/favorites/1",
          "host": ["{{base_url}}"],
          "path": ["favorites", "1"]
        }
      }
    },
    {
      "name": "Delete Favorite",
      "request": {
        "method": "DELETE",
        "header": [],
        "url": {
          "raw": "{{base_url}}/favorites/1",
          "host": ["{{base_url}}"],
          "path": ["favorites", "1"]
        }
      }
    }
  ]
}
